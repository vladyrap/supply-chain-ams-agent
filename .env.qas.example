# =============================================================================
# AMS Agent Backend — ambiente QAS
# =============================================================================
# Backend interno puerto 8000; expuesto en host como 6801.

NODE_ENV=production
LOG_LEVEL=info
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- LLM: Gemini (key SEPARADA para no compartir quota con DEV/PROD) ---
GEMINI_API_KEY=your_gemini_qas_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Postgres ---
POSTGRES_USER=ams_user
POSTGRES_PASSWORD=CAMBIAR_EN_VPS_QAS
POSTGRES_DB=ams_agent_qas
DATABASE_URL=postgresql://ams_user:CAMBIAR_EN_VPS_QAS@supply-chain-ams-db-qas:5432/ams_agent_qas

# --- Redis (db 1 para QAS) ---
REDIS_URL=redis://supply-chain-ams-redis-qas:6379/0

# --- RAG (igual que DEV) ---
RAG_ENABLED=true
RAG_TOP_K=6
RAG_MIN_SCORE=0.55
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768
RAG_CHUNK_CHARS=3500
RAG_CHUNK_OVERLAP=400

AMS_BOOTSTRAP_ADMIN_EMAIL=admin@qas.amsplatform.tudominio
AMS_BOOTSTRAP_ADMIN_PASSWORD=CAMBIAR_EN_VPS_QAS
