# =========================================
# supply-chain-ams-agent — variables locales
# =========================================
# Copiar este archivo a .env y completar.
# NUNCA commitear .env con valores reales.

# --- LLM provider: Google Gemini (tier free) ---
# Obtén tu key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Si quieres volver a Anthropic más adelante, sustituye claude.service.ts y
# usa estas variables en su lugar:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# --- PostgreSQL ---
POSTGRES_USER=ams_user
POSTGRES_PASSWORD=ams_password
POSTGRES_DB=ams_agent
DATABASE_URL=postgresql://ams_user:ams_password@supply-chain-ams-db:5432/ams_agent

# --- Redis ---
REDIS_URL=redis://supply-chain-ams-redis:6379

# --- Puertos internos (NO cambiar salvo razon fuerte) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- RAG documental (Fase 2) ---
# Cuando RAG_ENABLED=true y la pregunta tiene similitud > threshold, el agente
# inyecta los chunks recuperados como contexto.
RAG_ENABLED=true
RAG_TOP_K=6
RAG_MIN_SCORE=0.55
# Modelo de embeddings (gratis en tier free, 768 dims)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768
# Tamaño objetivo de chunk en caracteres (aprox 4 chars = 1 token)
RAG_CHUNK_CHARS=3500
RAG_CHUNK_OVERLAP=400

# --- Auth (Fase 6) ---
# Si están seteadas y aún no hay usuarios, se crea un admin al primer arranque.
# AMS_BOOTSTRAP_ADMIN_EMAIL=admin@miempresa.com
# AMS_BOOTSTRAP_ADMIN_PASSWORD=cambia-esto
COOKIE_SECRET=cambia-esto-en-prod-please
CORS_ORIGINS=http://localhost:6700,http://localhost:6600,http://127.0.0.1:6700,http://127.0.0.1:6600

# --- Whisper / Reuniones (Fase 5) ---
WHISPER_URL=http://supply-chain-ams-whisper:9000

# --- Tickets Jira (Fase 3) ---
# Si están seteadas, /api/tickets va contra Jira real. Si no, devuelve mock.
# JIRA_BASE_URL=https://tuempresa.atlassian.net
# JIRA_EMAIL=tu@empresa.com
# JIRA_API_TOKEN=ATATT3xFfGF0...
# JIRA_PROJECT_KEY=AMS

# --- SAP Read-Only (Fase 4) ---
# Si están seteadas, /api/sap/* puede ir contra OData real (modo lectura, catálogo blanco).
# Si no, devuelve mock con datos sintéticos representativos.
# SAP_BASE_URL=https://my-s4-system.ondemand.com
# SAP_USER=AMS_AGENT_RO
# SAP_PASSWORD=
# SAP_CLIENT=100
# SAP_READONLY_ENABLED=true
# SAP_DEFAULT_TOP=50

# --- SMTP para Integraciones tipo Email (Fase 3) ---
# Si están seteadas, las destinations tipo "email" funcionan; si no, fallan
# con mensaje claro pero no rompen el resto. Para Gmail usa app password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@empresa.com
# SMTP_PASSWORD=
# SMTP_FROM="AMS Platform <ams-bot@empresa.com>"

# --- Frontend ---
# URL publica que el navegador usa para llamar al backend (puerto host).
FRONTEND_PUBLIC_API_URL=http://localhost:6601
