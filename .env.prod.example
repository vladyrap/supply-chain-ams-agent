# =============================================================================
# AMS Agent Backend — ambiente PROD
# =============================================================================
# Backend interno puerto 8000; expuesto en host como 6901.
# CRÍTICO: las credenciales acá afectan a clientes reales. Custodiarlas.

NODE_ENV=production
LOG_LEVEL=warn   # menos verbose en PRD
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- LLM: Gemini PROD (key separada con quota dedicada) ---
GEMINI_API_KEY=your_gemini_prod_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Postgres PROD ---
POSTGRES_USER=ams_user
POSTGRES_PASSWORD=USAR_PASSWORD_FUERTE_EN_VPS
POSTGRES_DB=ams_agent_prod
DATABASE_URL=postgresql://ams_user:USAR_PASSWORD_FUERTE_EN_VPS@supply-chain-ams-db-prod:5432/ams_agent_prod

# --- Redis (db 2 para PROD) ---
REDIS_URL=redis://supply-chain-ams-redis-prod:6379/0

# --- RAG ---
RAG_ENABLED=true
RAG_TOP_K=6
RAG_MIN_SCORE=0.55
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768
RAG_CHUNK_CHARS=3500
RAG_CHUNK_OVERLAP=400

AMS_BOOTSTRAP_ADMIN_EMAIL=admin@amsplatform.tudominio
AMS_BOOTSTRAP_ADMIN_PASSWORD=USAR_PASSWORD_FUERTE_EN_VPS

# --- Sentry (REQUERIDO en PROD) ---
SENTRY_DSN=

# --- Jira (cuando se conecte real) ---
# JIRA_BASE_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=
