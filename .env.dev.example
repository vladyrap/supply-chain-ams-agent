# =============================================================================
# AMS Agent Backend — ambiente DEV
# =============================================================================
# Copiar a .env.dev en el VPS y completar.
# Backend interno puerto 8000; expuesto en host como 6601.

NODE_ENV=production
LOG_LEVEL=info
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- LLM: Gemini ---
GEMINI_API_KEY=your_gemini_dev_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Postgres (db separada por ambiente) ---
POSTGRES_USER=ams_user
POSTGRES_PASSWORD=CAMBIAR_EN_VPS_DEV
POSTGRES_DB=ams_agent_dev
DATABASE_URL=postgresql://ams_user:CAMBIAR_EN_VPS_DEV@supply-chain-ams-db-dev:5432/ams_agent_dev

# --- Redis (db 0 para DEV) ---
REDIS_URL=redis://supply-chain-ams-redis-dev:6379/0

# --- RAG ---
RAG_ENABLED=true
RAG_TOP_K=6
RAG_MIN_SCORE=0.55
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768
RAG_CHUNK_CHARS=3500
RAG_CHUNK_OVERLAP=400

# --- Bootstrap admin (solo primer arranque) ---
AMS_BOOTSTRAP_ADMIN_EMAIL=admin@dev.amsplatform.tudominio
AMS_BOOTSTRAP_ADMIN_PASSWORD=CAMBIAR_EN_VPS_DEV

# --- Mock LLM (útil para demos sin quota) ---
# FORCE_MOCK_LLM=1
