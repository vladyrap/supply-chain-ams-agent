{
  "name": "supply-chain-ams-backend",
  "version": "0.1.0",
  "description": "Backend Fastify para el Agente AMS Supply Chain",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:smoke": "tsx scripts/smoke-health.ts && tsx scripts/smoke-rbac.ts && tsx scripts/smoke-audit.ts && tsx scripts/smoke-tickets.ts",
    "test:smoke:health": "tsx scripts/smoke-health.ts",
    "test:smoke:rbac": "tsx scripts/smoke-rbac.ts",
    "test:smoke:audit": "tsx scripts/smoke-audit.ts",
    "test:smoke:tickets": "tsx scripts/smoke-tickets.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/oauth2": "^7.9.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@google/genai": "^0.7.0",
    "@sentry/node": "^7.120.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.21.2",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "prom-client": "^15.1.3",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
